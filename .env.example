# =============================================================================
# Chatterbuzz SEO Platform — Environment Variables
# Copy to .env and fill in values
# =============================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# --- Google OAuth (GA4/GSC) ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# --- Anthropic AI ---
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Asana ---
ASANA_PAT=your-asana-personal-access-token
ASANA_WORKSPACE_ID=your-workspace-id
ASANA_PROJECT_ID=your-project-id

# --- WordPress CMS ---
WP_BASE_URL=https://your-site.com/wp-json/wp/v2
WP_APP_USER=your-app-username
WP_APP_PASSWORD=your-application-password

# --- Webflow CMS ---
WEBFLOW_API_TOKEN=your-webflow-api-token
WEBFLOW_SITE_ID=your-webflow-site-id
WEBFLOW_COLLECTION_ID=your-collection-id

# --- Google Business Profile ---
GBP_API_KEY=your-gbp-api-key
GBP_ACCOUNT_ID=your-gbp-account-id

# --- FastAPI Gateway ---
API_SECRET_KEY=your-api-secret-key
API_RATE_LIMIT=100

# --- n8n Webhooks ---
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=your-n8n-api-key

# --- Existing Vercel WQA App ---
SECRET_KEY=your-existing-secret-key
