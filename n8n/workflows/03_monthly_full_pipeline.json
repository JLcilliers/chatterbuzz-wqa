{
  "name": "03 - Monthly Full Pipeline",
  "nodes": [
    {
      "parameters": { "rule": { "interval": [{ "field": "cronExpression", "expression": "0 1 1 * *" }] } },
      "name": "Cron - 1st of Month 01:00 UTC",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [250, 300]
    },
    {
      "parameters": {
        "url": "={{$env.API_BASE_URL}}/webhooks/full-pipeline/{{$env.CLIENT_ID}}",
        "method": "POST",
        "headerParameters": { "parameters": [{ "name": "X-API-Key", "value": "={{$env.API_SECRET_KEY}}" }] }
      },
      "name": "Trigger Full Pipeline",
      "type": "n8n-nodes-base.httpRequest",
      "position": [500, 300]
    }
  ],
  "connections": { "Cron - 1st of Month 01:00 UTC": { "main": [[{ "node": "Trigger Full Pipeline", "type": "main", "index": 0 }]] } }
}
