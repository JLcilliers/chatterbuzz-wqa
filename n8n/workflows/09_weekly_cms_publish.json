{
  "name": "09 - Weekly CMS Publish",
  "nodes": [
    {
      "parameters": { "rule": { "interval": [{ "field": "cronExpression", "expression": "0 6 * * 3" }] } },
      "name": "Cron - Wednesday 06:00 UTC",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [250, 300]
    },
    {
      "parameters": {
        "url": "={{$env.API_BASE_URL}}/webhooks/cms-publish/{{$env.CLIENT_ID}}",
        "method": "POST",
        "headerParameters": { "parameters": [{ "name": "X-API-Key", "value": "={{$env.API_SECRET_KEY}}" }] }
      },
      "name": "Trigger CMS Publish",
      "type": "n8n-nodes-base.httpRequest",
      "position": [500, 300]
    }
  ],
  "connections": { "Cron - Wednesday 06:00 UTC": { "main": [[{ "node": "Trigger CMS Publish", "type": "main", "index": 0 }]] } }
}
